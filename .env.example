# Mission Control Environment Variables

# ── ANTHROPIC OAUTH TOKENS (subscription-based, prefix: sk-ant-oat01-) ──────
# Primary OAuth token — REQUIRED
ANTHROPIC_API_KEY=sk-ant-oat01-your-primary-token-here
# Backup OAuth token — used automatically if primary fails authentication
ANTHROPIC_API_KEY_BACKUP=sk-ant-oat01-your-backup-token-here

# JWT secret for authentication (change in production!)
JWT_SECRET=mission-control-dev-secret-change-in-prod

# Database (used by docker-compose, override for external DB)
POSTGRES_DB=mission_control
POSTGRES_USER=mc_user
POSTGRES_PASSWORD=mc_password
DATABASE_URL=postgresql+asyncpg://mc_user:mc_password@localhost:5432/mission_control

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

# Agent defaults
DEFAULT_MODEL=claude-sonnet-4-6
HEARTBEAT_TIMEOUT_SECONDS=120
COST_AGGREGATION_INTERVAL_SECONDS=300
