# Mission Control Environment Variables
# Copy to .env and fill in your values

# Backend
DATABASE_URL=postgresql+asyncpg://mc_user:mc_password@localhost:5432/mission_control
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-this-to-a-random-secret-key
LOG_LEVEL=INFO

# Agents - Using OpenRouter for cheap inference
ANTHROPIC_API_KEY=sk-or-v1-your-openrouter-key-here
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# Optional: backup key used automatically if primary fails authentication
ANTHROPIC_API_KEY_BACKUP=sk-or-v1-your-backup-key-here

# Frontend (set in .env.local for local dev)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Railway (for deployment)
# PORT is auto-set by Railway
