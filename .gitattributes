# ============================================================
# Mission Control — Line Ending Normalization
# Forces LF in repo, auto-converts to CRLF on Windows checkout
# Eliminates all "LF will be replaced by CRLF" warnings
# ============================================================

# Default: normalize all text files to LF in repo
* text=auto eol=lf

# Python — always LF
*.py    text eol=lf
*.pyi   text eol=lf

# Web / Frontend — always LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf

# Config / Infra — always LF
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.env   text eol=lf
*.sh    text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Docs
*.md    text eol=lf
*.txt   text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
