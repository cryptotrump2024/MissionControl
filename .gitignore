# ============================================================
# MISSION CONTROL — GITIGNORE
# SECURITY: This file MUST be committed BEFORE any other files
# ============================================================

# ── SECRETS & ENVIRONMENT (CRITICAL) ────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.secret
*credentials*
*token*
!**/src/**/token*
!**/types/**/token*

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Node / Frontend ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
.pnp.*

# ── Claude Code (local AI assistant config — not source code) ───
.claude/

# ── IDE ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Docker ─────────────────────────────────────────────────
docker-compose.override.yml

# ── Database ───────────────────────────────────────────────
*.sqlite3
*.db

# ── Agent workspace (runtime output, not source) ──────────
workspace/
workspace/drafts/
workspace/code/

# ── Testing ────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ── Build artifacts ────────────────────────────────────────
frontend/dist/
*.log
